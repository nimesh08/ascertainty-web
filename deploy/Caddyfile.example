# Exira Web — reference Caddyfile
#
# Replace <DOMAIN_OR_IP> with either a hostname (preferred; Caddy will
# auto-provision a Let's Encrypt cert) or a bare IP (Caddy will issue
# a shortlived cert for the IP which most browsers will warn about).
#
# Replace <ADMIN_EMAIL> with the address that should receive ACME
# renewal notifications.

{
    email <ADMIN_EMAIL>
    default_sni <DOMAIN_OR_IP>
}

<DOMAIN_OR_IP> {
    # For IP-only deployments, keep the shortlived ACME profile:
    #   tls { issuer acme { profile shortlived } }
    # For a real hostname, delete the `tls` block — Caddy defaults
    # to Let's Encrypt and will issue a long-lived cert automatically.
    tls {
        issuer acme {
            profile shortlived
        }
    }

    encode gzip

    # Next.js is supervised by pm2 on port 3100 (see deploy/ecosystem.config.js).
    reverse_proxy 127.0.0.1:3100
}

# Redirect http:// to https://
http://<DOMAIN_OR_IP> {
    redir https://{host}{uri} permanent
}
