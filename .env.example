# -----------------------------------------------------------------------------
# Exira Web — example environment file
#
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database — Neon Postgres (https://neon.tech/)
#
# The app uses `postgres-js` with `prepare: false` (Neon pooled connection).
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# -----------------------------------------------------------------------------
# Privy — https://dashboard.privy.io/
#
# `NEXT_PUBLIC_PRIVY_APP_ID` is safe in client bundles. `PRIVY_APP_SECRET`
# is server-only and used by `lib/privy/verify.ts` to verify access tokens
# via `@privy-io/server-auth`.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# -----------------------------------------------------------------------------
# Solana RPC
#
# Devnet is the primary cluster. A Helius endpoint (with API key) is
# recommended for reliable WebSocket + high-rate JSON-RPC. Free public
# endpoints like https://api.devnet.solana.com work but are rate-limited.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOLANA_RPC="https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"
NEXT_PUBLIC_SOLANA_WS="wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"
NEXT_PUBLIC_SOLANA_MAINNET_RPC="https://api.mainnet-beta.solana.com"
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# Server-side indexer RPC override (optional). If unset, falls back to
# NEXT_PUBLIC_SOLANA_RPC. Use this to route server-side reads through a
# different (e.g. higher-limit) Helius key than the browser uses.
HELIUS_RPC_URL=""

# -----------------------------------------------------------------------------
# Exira Anchor program (devnet deployment)
#
# Program ID is public — this value is safe to commit. The default in
# `lib/solana/pda.ts` matches the currently-deployed devnet program.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_EXIRA_PROGRAM_ID="J7z1a2bwMEC8MchgZwskJZ8PzXg4UG674VgD8DuotJn2"

# -----------------------------------------------------------------------------
# Admin gate
#
# The base58 pubkey of the wallet allowed to access /admin and write
# admin-only endpoints. Also seeded into the `admin_wallets` table by
# `npm run db:seed-admin`.
# -----------------------------------------------------------------------------
ADMIN_WALLET="your-admin-wallet-base58-pubkey"

# -----------------------------------------------------------------------------
# Dev-only overrides — DO NOT SET IN PRODUCTION
#
# DEV_INDEXER_TOKEN + NEXT_PUBLIC_DEV_INDEXER_TOKEN: shared dev token that
#   lets the UI trigger POST /api/indexer/sync without a wallet signature.
#   Leave unset in prod.
# INDEXER_SECRET: alternative server-only shared secret for the same
#   endpoint (header `x-indexer-key`).
# DEV_ADMIN_PUBKEY: bypass Privy verification and pretend the request is
#   from this admin pubkey. Useful when Privy is not yet configured.
# -----------------------------------------------------------------------------
DEV_INDEXER_TOKEN=""
NEXT_PUBLIC_DEV_INDEXER_TOKEN=""
INDEXER_SECRET=""
DEV_ADMIN_PUBKEY=""

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV="development"
